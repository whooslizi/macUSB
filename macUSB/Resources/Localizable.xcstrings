          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選択したドライブ上のすべてのデータが削除されます。処理を開始してもよろしいですか？"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos os dados da unidade selecionada serao apagados. Tem certeza de que deseja iniciar o processo?"
