    "Przez 1 minutę nie udało się odzyskać połączenia internetowego. Nie udało się potwierdzić usunięcia plików tymczasowych." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Internetverbindung konnte 1 Minute lang nicht wiederhergestellt werden. Das Löschen temporärer Dateien konnte nicht bestätigt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Internet connection failed to recover for 1 minute. Failed to confirm deletion of temporary files."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión a Internet no se recuperó durante 1 minuto. No se pudo confirmar la eliminación de archivos temporales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion Internet n'a pas pu être rétablie pendant 1 minute. Échec de la confirmation de la suppression des fichiers temporaires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossibile ripristinare la connessione Internet per 1 minuto. Impossibile confermare l'eliminazione dei file temporanei."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
