    "• Brak instalatora? Użyj przycisku „Pobierz”" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Kein Installer? Benutzen Sie die Schaltfläche „Herunterladen“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• No installer? Use the \"Download\" button"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• ¿Sin instalador? Utilice el botón \"Descargar\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Pas d'installateur ? Utilisez le bouton \"Télécharger\""
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Nessun installatore? Utilizza il pulsante \"Scarica\"."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• インストーラーがありませんか? 「ダウンロード」ボタンを使用してください"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Não há instalador? Use o botão \"Baixar\""
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Нет установщика? Используйте кнопку «Скачать»"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Kurulumcu yok mu? \"İndir\" düğmesini kullanın"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Немає інсталятора? Скористайтеся кнопкою «Завантажити»."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Không có trình cài đặt? Sử dụng nút \"Tải xuống\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 没有安装程序？使用“下载”按钮"
          }
        }
      }
    },
    "• Do utworzenia instalatora potrzebny jest nośnik USB o pojemności minimum %@ GB" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Zum Erstellen des Installers ist ein USB-Laufwerk mit mindestens %@ GB erforderlich"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• A USB drive with a minimum capacity of %@ GB is required to create the installer"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Se requiere una memoria USB con una capacidad mínima de %@ GB para crear el instalador"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Une clé USB d'une capacité minimale de %@ Go est requise pour créer l'installateur"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Per creare il programma di installazione è necessaria un'unità USB con una capacità minima di %@ GB"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• インストーラを作成するには、最低%@GBの容量を持つUSBメモリが必要です"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• É necessário um pen drive com capacidade mínima de %@ GB para criar o instalador"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Для создания установщика требуется USB-накопитель емкостью не менее %@ ГБ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Yükleyiciyi oluşturmak için minimum %@ GB kapasiteli bir USB sürücüsüne ihtiyacınız vardır"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Для створення інсталятора потрібен USB-накопичувач мінімальним об’ємом %@ ГБ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Để tạo bộ cài đặt, bạn cần có ổ USB có dung lượng tối thiểu %@ GB"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 创建安装程序需要至少 %@ GB 容量的 U 盘"
          }
        }
      }
    },
    "• Dozwolone formaty plików to .dmg, .iso, .cdr oraz .app" : {
